---
import Layout from '../layouts/Layout.astro';

// Replace with your real Formspree form ID once the account exists.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/REPLACE_ME';

const capabilities = [
  {
    title: 'Discover what applies to you',
    body: 'Answer a few questions about your industry, size and locations. Compittu maps you to the licences, certifications and statutory obligations you are actually on the hook for — instead of a generic checklist.',
  },
  {
    title: 'Track status and renewals',
    body: 'Every obligation has an owner, a due date and a state. Renewals surface before they lapse, not after an inspector finds them.',
  },
  {
    title: 'Manage controls and evidence',
    body: 'Attach the document, the photo, the certificate. When someone asks how you comply, the proof is already filed against the control.',
  },
  {
    title: 'Monitor risk',
    body: 'See where exposure is concentrated across sites and functions, and which gaps are worth fixing first.',
  },
  {
    title: 'Stay audit-ready',
    body: 'Walk into an audit with the register, the evidence and the history already assembled. No week-long scramble.',
  },
  {
    title: 'AI-assisted operations',
    body: 'Let Compittu read the regulation, summarise what changed, and tell you which of your obligations it touches.',
  },
];

const industries = [
  'Hospitals & clinics',
  'Educational institutions',
  'Hotels',
  'Restaurants',
  'Manufacturing',
  'Retail',
  'Logistics',
];
---

<Layout>
  <header class="border-b border-border">
    <nav
      class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5"
      aria-label="Main"
    >
      <span class="text-lg font-semibold tracking-tight">Compittu</span>
      <a
        href="#waitlist"
        class="rounded-card bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
      >
        Join the waitlist
      </a>
    </nav>
  </header>

  <main>
    <section class="mx-auto max-w-5xl px-6 pt-20 pb-16 sm:pt-28">
      <p class="text-sm font-medium text-primary">
        Compliance · Risk · Governance
      </p>
      <h1
        class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight text-balance sm:text-6xl"
      >
        Compliance you can actually keep up with.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted-foreground text-pretty">
        Most businesses don't fail compliance because they don't care. They fail
        because nobody could say, on any given day, what applied to them and
        whether it was still valid. Compittu answers that question continuously.
      </p>
      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a
          href="#waitlist"
          class="rounded-card bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
        >
          Join the waitlist
        </a>
        <a
          href="#how"
          class="rounded-card border border-border px-6 py-3 text-sm font-medium transition-colors hover:bg-muted"
        >
          See how it works
        </a>
      </div>
    </section>

    <section class="border-y border-border bg-muted/40">
      <div class="mx-auto max-w-5xl px-6 py-14">
        <h2 class="text-xl font-semibold tracking-tight">
          The register nobody owns
        </h2>
        <p class="mt-4 max-w-2xl text-muted-foreground text-pretty">
          The fire safety certificate sits in a drawer. The food licence renewal
          lives in one person's inbox. The last audit's findings are in a
          spreadsheet that stopped being updated in March. Nothing is wrong
          until everything is, and by then the penalty is already written.
        </p>
      </div>
    </section>

    <section id="how" class="mx-auto max-w-5xl scroll-mt-8 px-6 py-20">
      <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        What Compittu does
      </h2>
      <div class="mt-10 grid gap-x-10 gap-y-9 sm:grid-cols-2">
        {
          capabilities.map((c) => (
            <div>
              <h3 class="font-medium">{c.title}</h3>
              <p class="mt-2 text-sm text-muted-foreground text-pretty">
                {c.body}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-border">
      <div class="mx-auto max-w-5xl px-6 py-16">
        <h2 class="text-xl font-semibold tracking-tight">Built for</h2>
        <ul class="mt-6 flex flex-wrap gap-3">
          {
            industries.map((i) => (
              <li class="rounded-card border border-border px-4 py-2 text-sm text-muted-foreground">
                {i}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section id="waitlist" class="scroll-mt-8 border-t border-border bg-muted/40">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
          Get early access
        </h2>
        <p class="mt-4 max-w-xl text-muted-foreground text-pretty">
          We're onboarding a small number of businesses ahead of launch. Leave
          your email and we'll be in touch about the pilot.
        </p>
        <form
          action={FORMSPREE_ENDPOINT}
          method="POST"
          class="mt-8 flex max-w-md flex-col gap-3 sm:flex-row"
        >
          <label for="email" class="sr-only">Work email</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            placeholder="you@company.com"
            class="flex-1 rounded-card border border-border bg-background px-4 py-3 text-sm outline-none focus-visible:ring-2 focus-visible:ring-ring"
          />
          <button
            type="submit"
            class="rounded-card bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
          >
            Request access
          </button>
        </form>
      </div>
    </section>
  </main>

  <footer class="border-t border-border">
    <div
      class="mx-auto flex max-w-5xl flex-col gap-2 px-6 py-8 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between"
    >
      <span>&copy; {new Date().getFullYear()} Compittu</span>
      <a href="mailto:raghu@asettu.com" class="hover:text-foreground">
        raghu@asettu.com
      </a>
    </div>
  </footer>
</Layout>
